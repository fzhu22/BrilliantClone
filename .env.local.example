# Copy this file to .env.local and fill in the values from your Firebase project.
# Firebase console -> Project settings -> General -> "Your apps" -> SDK setup and configuration.
# All keys are public client-side config (safe to expose); access is controlled by
# Firebase Auth + Firestore security rules, not by hiding these values.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- AI tutor (OpenAI via a Cloud Function) ---
# Turns on AI-generated hints + adaptive scaffolding. Leave "false" (or unset) to
# use the built-in hand-written hints with no AI calls. Before flipping to "true":
#   1) Set the function secret:  firebase functions:secrets:set OPENAI_API_KEY
#   2) Deploy the function:       firebase deploy --only functions --project brilliant-1fe5c
#   3) (Recommended) set up App Check and fill in the reCAPTCHA key below.
# NOTE: the OpenAI key is a SERVER-SIDE Cloud Function secret - never put it in a
# NEXT_PUBLIC_* variable, or it would be exposed in the browser bundle.
NEXT_PUBLIC_AI_ENABLED=false

# App Check (reCAPTCHA Enterprise) site key. Recommended before using AI in
# production so the tutor function can't be abused from the public site. Leave
# blank to skip App Check (e.g. local dev). Register the site in the Firebase
# console: App Check -> Apps -> reCAPTCHA Enterprise. (Then set enforceAppCheck:
# true in functions/src/index.ts.)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
